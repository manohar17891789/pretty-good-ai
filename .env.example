# --- Twilio (telephony) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The single Twilio number used as the caller for every test call.
TWILIO_CALLER_NUMBER=+1XXXXXXXXXX

# Public base URL Twilio will hit for webhooks (e.g. your ngrok https URL,
# no trailing slash). Update this every time you restart ngrok.
PUBLIC_BASE_URL=https://your-ngrok-subdomain.ngrok-free.app

# Port the local Flask webhook server listens on.
PORT=5000

# --- OpenAI (conversation + transcription + bug analysis) ---
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1

# --- Safety ---
# Hardcoded in src/safety.py as well. This is for visibility only; changing
# this value does NOT change which number the bot is allowed to call.
ALLOWED_TEST_NUMBER=+18054398008
